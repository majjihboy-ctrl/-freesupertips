# --- Frontend (exposed to the browser, must be prefixed VITE_) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_FOOTBALL_KEY=
VITE_ADMIN_EMAILS=you@example.com,otheradmin@example.com

# --- Backend only (Vercel serverless functions in /api — never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Scraper automation ---
# The scraper (hybrid-scraper.js) now runs automatically every 3 hours via
# .github/workflows/scrape.yml. For that to work, add these as GitHub
# repo secrets (Settings → Secrets and variables → Actions → New repository
# secret) — same values as above, just entered on GitHub instead of here:
#   VITE_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   VITE_API_FOOTBALL_KEY
#   VITE_BZZOIRO_API_KEY
# You can also trigger a run manually anytime from the repo's Actions tab.
# 'sandbox' (default, simulates payments) or 'production' (real money, needs go-live creds)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a publicly reachable HTTPS URL Safaricom can POST to, e.g.
# https://freesupertips.vercel.app/api/mpesa/callback
MPESA_CALLBACK_URL=
