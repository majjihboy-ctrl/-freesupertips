# --- Frontend (exposed to the browser, must be prefixed VITE_) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_FOOTBALL_KEY=
VITE_ADMIN_EMAILS=you@example.com,otheradmin@example.com

# --- Backend only (Vercel serverless functions in /api — never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=
# 'sandbox' (default, simulates payments) or 'production' (real money, needs go-live creds)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a publicly reachable HTTPS URL Safaricom can POST to, e.g.
# https://freesupertips.vercel.app/api/mpesa/callback
MPESA_CALLBACK_URL=
